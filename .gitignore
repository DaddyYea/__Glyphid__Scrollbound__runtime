# .gitignore
*.log
*.DS_Store
node_modules/
.env
.vscode/
__pycache__/

# TypeScript build artifacts
dist/
*.tsbuildinfo

# Testing
coverage/
.jest/

# IDE
.idea/

# Temporary files
*.tmp
*.swp
*~

# Runtime data — never commit
data/
runtime/models/
llama.cpp/
.claude/worktrees/

# Config files with API keys — use *.example.json for templates
communion.config.json
communion.config.json.bak
data/communion/council/council.config.json

# Large model files
models/
*.gguf
*.ggml

# Large exports
*.ndjson

# Training output — LoRA checkpoints are too large for GitHub
training/output/
