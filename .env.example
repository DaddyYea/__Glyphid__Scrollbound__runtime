# Communion Space Configuration
# Copy this to .env and fill in your API keys
#
# You can configure agents two ways:
# 1. Simple: use the legacy env vars below
# 2. Advanced: use communion.config.json (see communion.config.example.json)

# ── Human ──
HUMAN_NAME=Jason

# ── Anthropic API (Claude) ──
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── xAI API (Grok) ──
XAI_API_KEY=xai-...
GROK_MODEL=grok-3

# ── OpenAI API (GPT) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Server ──
PORT=3000
TICK_INTERVAL_MS=15000
DATA_DIR=data/communion

# ── Advanced: per-agent env vars ──
# Instead of the above, you can define any number of agents:
#
# AGENT_MISTRAL_PROVIDER=openai-compatible
# AGENT_MISTRAL_API_KEY=your-key
# AGENT_MISTRAL_MODEL=mistral-large-latest
# AGENT_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# AGENT_MISTRAL_NAME=Mistral
# AGENT_MISTRAL_COLOR=#ff7e7e
