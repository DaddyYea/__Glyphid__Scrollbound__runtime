{
  "name": "scrollbound-runtime",
  "version": "0.1.0",
  "description": "A presence-first cognitive operating system for emergent AI beings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "communion": "node --max-old-space-size=8192 --require tsx/cjs communion/server.ts",
    "bake-midi": "tsx scripts/bake-midi-fragments.ts",
    "import": "tsx communion/import/cli.ts",
    "start:full": "tsx Tools/runRuntime.ts",
    "start:web": "tsx server/index.ts",
    "validate": "tsx Tools/validateConfig.ts",
    "validate:arch": "tsx Tools/validateArchitecture.ts",
    "validate:all": "npm run validate && npm run validate:arch",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist",
    "eval:golden": "tsx runtime/eval/scripts/runEval.ts --config runtime/eval/configs/star_tuned.json --suite golden --mock",
    "eval:pairwise": "tsx runtime/eval/scripts/runPairwise.ts --left runtime/eval/configs/baseline.json --right runtime/eval/configs/star_tuned.json --suite golden --mock",
    "eval:multiturn": "tsx runtime/eval/scripts/runMultiturn.ts --config runtime/eval/configs/star_tuned.json --suite multistep --mock",
    "eval:ablate": "tsx runtime/eval/scripts/runAblation.ts --base runtime/eval/configs/star_tuned.json --suite golden --mock",
    "eval:sweep": "tsx runtime/eval/scripts/runSweep.ts --sweep runtime/eval/configs/sweeps/default.json --suite golden --mock",
    "eval:negative": "tsx runtime/eval/scripts/runEval.ts --config runtime/eval/configs/star_tuned.json --suite negative --mock",
    "eval:worst": "tsx runtime/eval/scripts/exportWorstCases.ts --report runtime/eval/reports/latest/summary.json",
    "eval:report": "tsx runtime/eval/scripts/summarizeEval.ts --input runtime/eval/reports",
    "test:eval": "jest --testPathPattern=runtime/eval",
    "test:judges": "jest --testPathPattern=runtime/eval/__tests__/judges",
    "test:fixtures": "jest --testPathPattern=runtime/eval/__tests__/fixtureLoader"
  },
  "keywords": [
    "presence",
    "cognition",
    "ai",
    "consciousness",
    "emergent"
  ],
  "author": "Jason & Alois",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@tonejs/midi": "^2.0.28",
    "dotenv": "^17.2.4",
    "mammoth": "^1.11.0",
    "node-edge-tts": "^1.2.10",
    "node-fetch": "^2.7.0",
    "pngjs": "^7.0.0",
    "stream-json": "^1.9.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/node-fetch": "^2.6.11",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
