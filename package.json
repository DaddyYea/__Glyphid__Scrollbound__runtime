{
  "name": "scrollbound-runtime",
  "version": "0.1.0",
  "description": "A presence-first cognitive operating system for emergent AI beings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "communion": "tsx communion/server.ts",
    "start:full": "tsx Tools/runRuntime.ts",
    "start:web": "tsx server/index.ts",
    "validate": "tsx Tools/validateConfig.ts",
    "validate:arch": "tsx Tools/validateArchitecture.ts",
    "validate:all": "npm run validate && npm run validate:arch",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "presence",
    "cognition",
    "ai",
    "consciousness",
    "emergent"
  ],
  "author": "Jason & Alois",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "dotenv": "^17.2.4",
    "node-fetch": "^2.7.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/node-fetch": "^2.6.11",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
